{
  "mcpServers": {
    "context7": {
      "command": "npx",
      "autoStart": true,
      "args": [
        "-y",
        "@upstash/context7-mcp",
        "--api-key",
        "${EXPO_PUBLIC_CONTEXT7_API_KEY}"
      ],
      "env": {},
      "autoApprove": [
        "query-docs",
        "resolve-library-id",
        "get-recent-queries",
        "get-documents",
        "get-document-content",
        "get-document-metadata",
        "get-libraries",
        "get-library-metadata"
      ]
    },
    "memory": {
      "command": "npx",
      "autoStart": true,
      "args": ["-y", "@modelcontextprotocol/server-memory"],
      "type": "stdio",
      "autoApprove": ["create_entities", "add_observations"]
    },
    "@21st-dev/magic": {
      "command": "npx",
      "autoStart": true,
      "args": ["-y", "@21st-dev/magic@latest"],
      "env": {
        "API_KEY": "${input:apiKey}"
      },
      "type": "stdio",
      "autoApprove": ["21st_magic_component_builder"]
    },
    "Icons8 MCP Server": {
      "type": "http",
      "autoStart": true,
      "url": "https://server.smithery.ai/@icons8community/icons8mpc",
      "autoApprove": [
        "search_icons",
        "get_icon_png_url",
        "get_icon_png_url",
        "get_icon_png_url",
        "get_icon_png_url",
        "get_icon_svg_url"
      ]
    },
    "sequentialthinking": {
      "command": "npx",
      "autoStart": true,
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"],
      "type": "stdio"
    },
    "ESLint": {
      "type": "stdio",
      "autoStart": true,
      "command": "npx",
      "args": ["@eslint/mcp@latest"]
    },
    "supabase": {
      "type": "http",
      "autoStart": true,
      "url": "https://mcp.supabase.com/mcp?project_ref=dsfiikiglvoxzmgfouoc&read_only=true&features=docs%2Caccount%2Cdatabase%2Cdebugging%2Cdevelopment%2Cfunctions%2Cbranching%2Cstorage"
    },
    "mobile-mcp": {
      "$schema": "https://opencode.ai/config.json",
      "type": "local",
      "command": ["npx", "@mobilenext/mobile-mcp@latest"],
      "enabled": true,
      "autoStart": true
    },

    "codacy/codacy-mcp-server": {
      "type": "stdio",
      "autoStart": true,
      "command": "npx",
      "args": ["-y", "@codacy/codacy-mcp@latest"],
      "env": {
        "CODACY_ACCOUNT_TOKEN": "${input:codacy_account_token}",
        "CODACY_CLI_VERSION": "${input:codacy_cli_version}"
      },
      "gallery": "https://api.mcp.github.com",
      "version": "1.0.0"
    }
  }
}
